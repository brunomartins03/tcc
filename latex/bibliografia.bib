@article{de_toffoli_proofs_2024,
	title = {Proofs for a price: {Tomorrow}’s ultra-rigorous mathematical culture},
	volume = {61},
	copyright = {https://www.ams.org/publications/copyright-and-permissions},
	issn = {1088-9485, 0273-0979},
	shorttitle = {Proofs for a price},
	url = {https://www.ams.org/bull/2024-61-03/S0273-0979-2024-01823-0/},
	doi = {10.1090/bull/1823},
	abstract = {Computational tools might tempt us to renounce complete certainty. By forgoing of rigorous proof, we could get (very) probable results for a fraction of the cost. But is it really true that proofs (as we know and love them) can lead us to certainty? Maybe not. Proofs do not wear their correctness on their sleeve, and we are not infallible in checking them. This suggests that we need help to check our results. When our fellow mathematicians will be too tired or too busy to scrutinize our putative proofs, computer proof assistants could help. But feeding a mathematical argument to a computer is hard. Still, we might be willing to undertake the endeavor in view of the extra perks that formalization may bring—chieﬂy among them, an enhanced mathematical understanding.},
	language = {en},
	number = {3},
	urldate = {2026-04-22},
	journal = {Bulletin of the American Mathematical Society},
	author = {De Toffoli, Silvia},
	month = may,
