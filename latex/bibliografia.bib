@misc{patel_new_2024,
	title = {A {New} {Approach} {Towards} {Autoformalization}},
	url = {http://arxiv.org/abs/2310.07957},
	doi = {10.48550/arXiv.2310.07957},
	abstract = {Verifying mathematical proofs is difficult [15], but can be automated with the assistance of a computer. Autoformalization is the task of automatically translating natural language mathematics into a formal language that can be verified by a program. This is a challenging task, and especially for higher-level mathematics found in research papers. Research paper mathematics requires large amounts of background and context. In this paper, we propose an avenue towards tackling autoformalization for research-level mathematics, by breaking the task into easier and more approachable subtasks: unlinked formalization (formalization with unlinked definitions and theorems), entity linking (linking to the proper theorems and definitions), and finally adjusting types so it passes the type checker. In addition, we present arXiv2Formal,1 a benchmark dataset for unlinked formalization consisting of 50 theorems formalized for the Lean theorem prover [8] sampled from papers on arXiv.org.},
	language = {en},
	urldate = {2026-03-18},
